#!/usr/bin/env bash

show_help() {
    cat <<'EOF'
Usage: pipod [claude|codex|junie] [OPTIONS] [COMMAND] [-- ARGS...]

Run the pi, Claude Code, Codex, or Junie agent inside an isolated Docker
container. One persistent container is created per workspace directory, per
agent.

Commands:
  claude            Run the Claude Code agent instead of pi. This selects a
                    separate image and container (pipod-claude-...) and can be
                    combined with all options below, e.g. `pipod claude bash`.
  codex             Run the OpenAI Codex CLI agent instead of pi. This selects a
                    separate image and container (pipod-codex-...) and can be
                    combined with all options below, e.g. `pipod codex bash`.
  junie             Run the JetBrains Junie CLI agent instead of pi. This selects
                    a separate image and container (pipod-junie-...) and can be
                    combined with all options below, e.g. `pipod junie bash`.
  bash              Open an interactive bash shell inside the container
  stop              Stop the current workspace/agent container without removing it
                    (it is reused next time)

Options:
  -nn, --no-network Only allow access to the host (host.docker.internal), block the Internet.
                    Uses a separate container, so toggling -nn keeps each mode's installed packages.
  -r, --recreate    Force recreate the container (image is rebuilt from cache)
  --no-cache        Build the image without Docker cache (forces an agent upgrade)
  --no-tty          Allocate stdin (-i) but no pseudo-tty; for piping input or running
                    the agent non-interactively, e.g. `pipod --no-tty -- --print "..."`
  -h, --help        Show this help message and exit

Anything after `--` is forwarded to the agent (or to bash in shell mode) as its
own arguments, e.g. `pipod -- --print "summary"` runs `pi --print "summary"`.
EOF
}

# Scan the pipod config root (~/.pipod) for entries not owned by the
# invoking user and chown them back. Docker creates bind-mount sources as
# root when the host path is missing at `docker run`/`docker start` time, so a
# config tree that was deleted (or never created) can come back root-owned and
# trigger EACCES for the in-container ubuntu user — both root-owned ancestors
# (which would block the `mkdir -p` in prepare_config) and stale root-owned
# descendants left behind by an older mount layout. Requires `sudo -n` if
# anything is root-owned; otherwise exits with the exact command to run.
recover_root_owned() {
    local root="$1"
    [ -d "$root" ] || return 0
    local found
    found="$(find "$root" ! -uid "$(id -u)" -prune -print 2>/dev/null || true)"
    if [ -n "$found" ]; then
        if sudo -n true 2>/dev/null; then
            while IFS= read -r entry; do
                [ -n "$entry" ] && sudo chown -R "$(id -u):$(id -g)" "$entry"
            done <<< "$found"
        else
            echo "pipod: '$root' has root-owned entries; run: sudo chown -R $(id -u):$(id -g) \"$root\"" >&2
            exit 1
        fi
    fi
}

# Ensure the shared no-Internet network exists as an `--internal` bridge.
# `--internal` is what actually blocks egress (a masquerade-disabled network
# does not on every host); host access is preserved separately by pointing
# host.docker.internal at this network's on-link gateway. If a same-named
# network exists but isn't internal (a stale earlier attempt), recreate it —
# only possible when no container is attached, hence the -r guidance.
ensure_no_net_network() {
    local net="$1"
    if docker network inspect "$net" >/dev/null 2>&1; then
        [ "$(docker network inspect -f '{{.Internal}}' "$net")" = "true" ] && return
        docker network rm "$net" >/dev/null 2>&1 || {
            echo "pipod: '$net' exists with the wrong config and can't be removed (a container is still attached)." >&2
            echo "       Run './pipod -r -nn' to recreate the container first." >&2
            exit 1
        }
    fi
    echo "Creating no-Internet network $net"
    docker network create --internal "$net" >/dev/null
}

# Copy essential config from the host's agent dir into $dst_dir when missing,
# rewriting localhost/127.0.0.1 to host.docker.internal so locally-served
# models/gateways stay reachable. For pi: models.json + auth.json from
# ~/.pi/agent. For Claude Code: .credentials.json (auth) + settings.json from
# ~/.claude. For Codex: auth.json (auth) + config.toml from ~/.codex. For
# Junie: config.json (base settings + BYOK provider keys), settings.json (user
# settings, which Junie resolves at HIGHER precedence than config.json),
# allowlist.json (action allowlist), and secure_credentials.json (Junie's
# credential store) from ~/.junie. Junie's activation gate needs a
# JetBrains-Account credential (independent of the model profile); on the host
# it's usually in place with no separate login (reused from a JetBrains
# IDE/Toolbox sign-in). That credential lives in secure_credentials.json — which
# IS bootstrapped/mounted here, so it carries across automatically (no
# in-container login). The exception is hosts where Junie keeps the credential
# in the OS keyring instead (macOS Keychain / Windows Credential Manager / a
# Linux keyring Junie prefers): there is no file to copy, so log in once inside
# the container (it then writes the shared secure_credentials.json), use
# --auth/JUNIE_API_KEY, or put provider keys in config.json "byok" (built-in
# provider models only).
# The file set and source dir are agent-specific
# (BOOTSTRAP_FILES / BOOTSTRAP_SRC_DIR).
bootstrap_config() {
    local dst_dir="$1"
    local f src dst
    for f in "${BOOTSTRAP_FILES[@]}"; do
        src="$BOOTSTRAP_SRC_DIR/$f"
        dst="$dst_dir/$f"
        if [ ! -e "$dst" ] && [ -f "$src" ]; then
            echo "Using $src for $dst"
            sed -E 's/(localhost|127\.0\.0\.1)/host.docker.internal/g' "$src" > "$dst"
            chmod "$(stat -c '%a' "$src" 2>/dev/null || stat -f '%Lp' "$src")" "$dst"
        fi
    done
}

# Like bootstrap_config, but for a whole config subdirectory (e.g. Junie's
# models/, mcp/, skills/, commands/, agents/) — each a directory of
# profile/config files rather than a single file. Recursively copies every file
# from the host agent dir into $dst_dir/<sub> only when the destination file is
# missing (so anything created inside the container is preserved), applying the
# same localhost/127.0.0.1 -> host.docker.internal rewrite to text files
# (custom-model base URLs and MCP hosts commonly point at a local gateway).
# Binary files are copied verbatim so packaged skills/extensions aren't
# corrupted. Source base is the global BOOTSTRAP_SRC_DIR, mirroring
# bootstrap_config (which also seeds the per-workspace override from the host).
bootstrap_config_dir() {
    local dst_dir="$1" sub="$2"
    local src="$BOOTSTRAP_SRC_DIR/$sub"
    [ -d "$src" ] || return 0
    local dst="$dst_dir/$sub"
    mkdir -p "$dst"
    local f rel out mode
    while IFS= read -r -d '' f; do
        rel="${f#"$src"/}"
        out="$dst/$rel"
        [ -e "$out" ] && continue
        mkdir -p "$(dirname "$out")"
        if LC_ALL=C grep -qI . "$f" 2>/dev/null; then
            sed -E 's/(localhost|127\.0\.0\.1)/host.docker.internal/g' "$f" > "$out"
            mode="$(stat -c '%a' "$f" 2>/dev/null || stat -f '%Lp' "$f")"
            chmod "$mode" "$out"
        else
            cp -p "$f" "$out"
        fi
    done < <(find "$src" -type f -print0)
}

# Prepare host-side config before bringing up the container: recover any
# root-owned entries under the config root (so the dirs below can be created),
# create the shared config and per-workspace dirs, and bootstrap auth/settings
# from the host if missing. Runs on every invocation so a deleted config tree
# is recovered even when reusing a container.
prepare_config() {
    recover_root_owned "$CONFIG_DIR"
    mkdir -p "$SHARED_CONFIG_DIR" "$WS_AGENT_DIR"
    local entry f
    for entry in "${DATA_MOUNTS[@]}"; do
        mkdir -p "$WS_AGENT_DIR/${entry%%|*}"
    done
    for entry in "${DATA_FILE_MOUNTS[@]}"; do
        f="$WS_AGENT_DIR/${entry%%|*}"
        [ -f "$f" ] || : > "$f"
    done
    bootstrap_config "$SHARED_CONFIG_DIR"
    local d
    for d in "${BOOTSTRAP_DIRS[@]}"; do
        bootstrap_config_dir "$SHARED_CONFIG_DIR" "$d"
    done
    if [ -d "$OVERRIDE_SRC" ]; then
        bootstrap_config "$OVERRIDE_SRC"
        for d in "${BOOTSTRAP_DIRS[@]}"; do
            bootstrap_config_dir "$OVERRIDE_SRC" "$d"
        done
    fi
}

# Parse pipod's own CLI args into module-level globals: AGENT, RECREATE,
# NO_CACHE, SHELL_MODE, STOP_MODE, NO_NETWORK, NO_TTY, EXTRA_ARGS. Anything
# after `--` is captured verbatim into EXTRA_ARGS for forwarding to the agent
# (or to bash in shell mode), bypassing pipod's own flags. Extracted so the
# parser is unit-testable.
parse_args() {
    RECREATE=false
    NO_CACHE=""
    SHELL_MODE=false
    STOP_MODE=false
    NO_NETWORK=false
    NO_TTY=false
    AGENT=pi
    EXTRA_ARGS=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --)             shift; EXTRA_ARGS=("$@"); break ;;
            -nn|--no-network) NO_NETWORK=true; shift ;;
            -r|--recreate) RECREATE=true; shift ;;
            --no-cache)   NO_CACHE=--no-cache; shift ;;
            --no-tty)     NO_TTY=true; shift ;;
            -h|--help)    show_help; exit 0 ;;
            claude)       AGENT=claude; shift ;;
            codex)        AGENT=codex; shift ;;
            junie)        AGENT=junie; shift ;;
            bash)         SHELL_MODE=true; shift ;;
            stop)         STOP_MODE=true; shift ;;
            *) echo "pipod: unknown option: $1" >&2; show_help >&2; exit 1 ;;
        esac
    done
}

# Set agent-specific globals (AGENT_LABEL, IMAGE_TAG, CONTAINER_PREFIX,
# BUILD_DIR, mounts, env, BOOTSTRAP_*, RUN_CMD, …) based on $AGENT. Depends on
# $PROJECT_DIR, $CONFIG_DIR, $WS_DIR, and $HOME being set by the caller —
# extracted so the per-agent RUN_CMD is unit-testable. See the comment block
# below (in the main flow, where this is called) for the full layout rationale.
select_agent() {
    BOOTSTRAP_DIRS=()
    if [ "$AGENT" = codex ]; then
        AGENT_LABEL="Codex CLI"
        IMAGE_TAG="pipod-codex"
        CONTAINER_PREFIX="pipod-codex"
        BUILD_DIR="$PROJECT_DIR/codex"
        AGENT_KEY="codex"
        WS_AGENT_DIR="$WS_DIR/$AGENT_KEY"
        SHARED_CONFIG_DIR="$CONFIG_DIR/codex"
        OVERRIDE_SRC="$WS_AGENT_DIR/config"
        CONFIG_MOUNT_SRC="$CONFIG_DIR/codex"
        CONFIG_MOUNT_DEST="/home/ubuntu/.codex"
        OVERRIDE_DEST="/home/ubuntu/.codex"
        CONFIG_ROOT="/home/ubuntu/.codex"
        DATA_MOUNTS=(
            "sessions|/home/ubuntu/.codex/sessions"
            "state|/home/ubuntu/.codex/state"
            "log|/home/ubuntu/.codex/log"
        )
        DATA_FILE_MOUNTS=("history.jsonl|/home/ubuntu/.codex/history.jsonl")
        AGENT_ENV=(-e "CODEX_HOME=/home/ubuntu/.codex" -e "CODEX_SQLITE_HOME=/home/ubuntu/.codex/state")
        BOOTSTRAP_SRC_DIR="$HOME/.codex"
        BOOTSTRAP_FILES=(auth.json config.toml)
        RUN_CMD=(codex --yolo)
    elif [ "$AGENT" = claude ]; then
        AGENT_LABEL="Claude Code"
        IMAGE_TAG="pipod-claude"
        CONTAINER_PREFIX="pipod-claude"
        BUILD_DIR="$PROJECT_DIR/claude"
        AGENT_KEY="claude"
        WS_AGENT_DIR="$WS_DIR/$AGENT_KEY"
        SHARED_CONFIG_DIR="$CONFIG_DIR/claude"
        OVERRIDE_SRC="$WS_AGENT_DIR/config"
        CONFIG_MOUNT_SRC="$CONFIG_DIR/claude"
        CONFIG_MOUNT_DEST="/home/ubuntu/.claude"
        OVERRIDE_DEST="/home/ubuntu/.claude"
        CONFIG_ROOT="/home/ubuntu/.claude"
        DATA_MOUNTS=(
            "sessions|/home/ubuntu/.claude/projects"
            "file-history|/home/ubuntu/.claude/file-history"
        )
        DATA_FILE_MOUNTS=("history.jsonl|/home/ubuntu/.claude/history.jsonl")
        AGENT_ENV=(-e "CLAUDE_CONFIG_DIR=/home/ubuntu/.claude")
        BOOTSTRAP_SRC_DIR="$HOME/.claude"
        BOOTSTRAP_FILES=(.credentials.json settings.json)
        RUN_CMD=(claude)
    elif [ "$AGENT" = junie ]; then
        AGENT_LABEL="Junie CLI"
        IMAGE_TAG="pipod-junie"
        CONTAINER_PREFIX="pipod-junie"
        BUILD_DIR="$PROJECT_DIR/junie"
        AGENT_KEY="junie"
        WS_AGENT_DIR="$WS_DIR/$AGENT_KEY"
        SHARED_CONFIG_DIR="$CONFIG_DIR/junie"
        OVERRIDE_SRC="$WS_AGENT_DIR/config"
        CONFIG_MOUNT_SRC="$CONFIG_DIR/junie"
        CONFIG_MOUNT_DEST="/home/ubuntu/.junie"
        OVERRIDE_DEST="/home/ubuntu/.junie"
        CONFIG_ROOT="/home/ubuntu/.junie"
        # Junie has no documented config-dir env var, so its fixed ~/.junie home
        # is mounted directly (the container HOME is /home/ubuntu, so ~/.junie is
        # /home/ubuntu/.junie). The platform binary + versions live under
        # ~/.local/share/junie, baked into the image (per-container like the other
        # agents' npm packages), so they are not bind-mounted. Per-task transcripts
        # (under cli-sessions/sessions) and logs are isolated per workspace like
        # the other agents' session data.
        DATA_MOUNTS=(
            "sessions|/home/ubuntu/.junie/cli-sessions/sessions"
            "log|/home/ubuntu/.junie/logs"
        )
        DATA_FILE_MOUNTS=()
        AGENT_ENV=()
        BOOTSTRAP_SRC_DIR="$HOME/.junie"
        BOOTSTRAP_FILES=(config.json settings.json allowlist.json secure_credentials.json)
        # Junie discovers several features from per-user DIRECTORIES under
        # ~/.junie (each a folder of profile/config files), so bootstrap them in
        # addition to the single-file set above: models/ (custom model profiles,
        # which embed their own BYOK key/base URL), mcp/ (MCP servers), skills/,
        # commands/ (custom slash commands), agents/ (custom agents). extensions/
        # is excluded (downloaded/cached binaries, not config).
        BOOTSTRAP_DIRS=(models mcp skills commands agents)
        RUN_CMD=(junie)
    else
        AGENT_LABEL="pi"
        IMAGE_TAG="pipod-pi-coding-agent"
        CONTAINER_PREFIX="pipod"
        BUILD_DIR="$PROJECT_DIR/pi"
        AGENT_KEY="pi"
        WS_AGENT_DIR="$WS_DIR/$AGENT_KEY"
        SHARED_CONFIG_DIR="$CONFIG_DIR/agent"
        OVERRIDE_SRC="$WS_AGENT_DIR/config"
        CONFIG_MOUNT_SRC="$CONFIG_DIR"
        CONFIG_MOUNT_DEST="/home/ubuntu/.pi"
        OVERRIDE_DEST="/home/ubuntu/.pi/agent"
        CONFIG_ROOT="/home/ubuntu/.pi"
        DATA_MOUNTS=("sessions|/home/ubuntu/.pi/agent/sessions")
        DATA_FILE_MOUNTS=()
        AGENT_ENV=(-e "PI_CODING_AGENT_DIR=/home/ubuntu/.pi/agent")
        BOOTSTRAP_SRC_DIR="$HOME/.pi/agent"
        BOOTSTRAP_FILES=(models.json auth.json)
        RUN_CMD=(pi)
    fi
}

# When sourced (e.g. by the test suite), expose the functions above without
# enabling strict mode or running the main flow.
if [[ "${BASH_SOURCE[0]}" != "${0}" ]]; then
    return 0 2>/dev/null || true
fi

set -euo pipefail

if [ -w /proc/self/comm ]; then
    echo pipod > /proc/self/comm || true
fi

parse_args "$@"

if ! command -v docker &>/dev/null; then
    echo "pipod: Docker is not installed (or not on PATH). Please install Docker and try again." >&2
    exit 1
fi

PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE_DIR="$(pwd)"
CONFIG_DIR="$HOME/.pipod"
# One-time move off the pre-split location (~/.pi/pipod, a subdir of the host's
# own pi config) to a self-contained ~/.pipod. Runs before any other path is
# derived from $CONFIG_DIR.
OLD_CONFIG_DIR="$HOME/.pi/pipod"
if [ ! -e "$CONFIG_DIR" ] && [ -d "$OLD_CONFIG_DIR" ]; then
    echo "pipod: relocating state $OLD_CONFIG_DIR -> $CONFIG_DIR"
    mv "$OLD_CONFIG_DIR" "$CONFIG_DIR"
fi
WS_SLUG="${WORKSPACE_DIR//[^a-zA-Z0-9_-]/_}"
WS_DIR="$CONFIG_DIR/workspaces/$WS_SLUG"

# Agent-specific layout. Each agent gets its own image, container-name prefix,
# Dockerfile subdir, and config mount. Per-workspace state is split by agent:
# under $WS_DIR/<agent>/ (pi/claude/codex/junie) lives that agent's per-project
# data (DATA_MOUNTS / DATA_FILE_MOUNTS, bind-mounted over the shared agent home
# so it shadows just those paths) plus an optional config/ override that replaces
# the shared agent config for this one workspace. The shared agent home
# ($CONFIG_MOUNT_SRC) holds only config identical across every workspace:
# settings, auth, skills, plugins, etc.
#
# What counts as per-project data (per code.claude.com/docs,
# developers.openai.com/codex, and junie.jetbrains.com/docs):
#   claude  ~/.claude/projects (transcripts, auto memory, subagents, tool-results;
#          the in-container cwd is always /workspace, so every workspace would
#          otherwise map to the SAME project key and clobber each other),
#          ~/.claude/file-history (checkpoint snapshots), ~/.claude/history.jsonl
#          (prompt history / up-arrow recall).
#   codex   ~/.codex/sessions (rollout transcripts), ~/.codex/state (SQLite DBs via
#          CODEX_SQLITE_HOME — sharing these across projects corrupts the WAL and
#          wedges startup with SQLITE_CANTOPEN), ~/.codex/log, ~/.codex/history.jsonl.
#   junie   ~/.junie/cli-sessions/sessions (per-task transcripts: events.jsonl,
#          transcript.md, subagents/), ~/.junie/logs (app + upgrade logs).
#
# Auto-cleaned ephemera (shell-snapshots, paste/image caches, session-env, debug,
# plans, tasks, statsig) and Codex's self-update package cache are left in the
# shared home on purpose: they are keyed by session UUID (so they never collide
# across workspaces) and are transient, so isolating them adds bind mounts for no
# benefit.
#
# Note: Claude Code's ~/.claude.json (app state, per-project trust) is not
# relocatable via CLAUDE_CONFIG_DIR. It lives in $HOME inside the container;
# since containers are per-workspace (pipod-claude-<ws>), each workspace already
# keeps its own, and auth persists through the shared .credentials.json.
select_agent

CONTAINER_NAME="$CONTAINER_PREFIX-$WS_SLUG"
[ "$NO_NETWORK" = true ] && CONTAINER_NAME="${CONTAINER_NAME}-nonet"
# Shared `--internal` Docker network used by `--no-network`: it blocks all
# egress to the Internet. The host stays reachable because host.docker.internal
# is pointed at this network's on-link gateway (NOT `host-gateway`, which
# resolves to docker0 and would be off-subnet/unreachable here).
NO_NET_NETWORK="pipod-no-net"

# `stop` short-circuits before any build/create/recreate work: it kills the
# workspace/agent container in place.
if [ "$STOP_MODE" = true ]; then
    STATUS=$(docker inspect -f '{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null || echo "missing")
    case "$STATUS" in
        running|paused|created)
            echo "Stopping $CONTAINER_NAME"
            docker kill "$CONTAINER_NAME" >/dev/null 2>&1 || true
            ;;
        exited|dead)
            echo "$CONTAINER_NAME is not running"
            ;;
        *)
            echo "pipod: container $CONTAINER_NAME does not exist" >&2
            exit 1
            ;;
    esac
    exit 0
fi

# Remove existing container if -r.
EXISTING=$(docker ps -aq -f name=^${CONTAINER_NAME}$)
if [ -n "$EXISTING" ] && [ "$RECREATE" = true ]; then
    docker rm -f "$CONTAINER_NAME" >/dev/null 2>&1 || true
    EXISTING=""
fi

# Prompt to recreate; clears EXISTING on yes.
confirm_recreate() {
    local message="$1"
    echo "Configuration for $CONTAINER_NAME is out of date:"
    echo "$message"
    echo "Recreating applies the new config but discards anything installed inside the container (apt/npm packages, etc.)."
    read -r -p "Recreate $CONTAINER_NAME? (Y/n) " _answer || _answer=""
    if [[ ! "$_answer" =~ ^[Nn] ]]; then
        echo "Recreating $CONTAINER_NAME"
        docker rm -f "$CONTAINER_NAME" >/dev/null 2>&1 || true
        EXISTING=""
    else
        echo "Keeping $CONTAINER_NAME; the new config will not take effect this run (use ./pipod -r to force)."
    fi
}

if [ -n "$EXISTING" ]; then
    # End with `true` so the brace group exits 0 even when the conditional
    # `&& printf` short-circuits (OVERRIDE_SRC absent) — otherwise `set -euo
    # pipefail` aborts the pipeline here.
    expected=$( {
        printf '%s -> /workspace\n' "$WORKSPACE_DIR"
        # When the override replaces the whole shared config dir (Claude/Codex,
        # where OVERRIDE_DEST == CONFIG_MOUNT_DEST — CLAUDE_CONFIG_DIR/CODEX_HOME
        # are monolithic), it is mounted INSTEAD of the shared config (two binds
        # can't share one destination). For pi the override targets a subpath
        # (~/.pi/agent) and mounts alongside the shared ~/.pi.
        if [ -d "$OVERRIDE_SRC" ] && [ "$OVERRIDE_DEST" = "$CONFIG_MOUNT_DEST" ]; then
            printf '%s -> %s\n' "$OVERRIDE_SRC" "$CONFIG_MOUNT_DEST"
        else
            printf '%s -> %s\n' "$CONFIG_MOUNT_SRC" "$CONFIG_MOUNT_DEST"
            [ -d "$OVERRIDE_SRC" ] && printf '%s -> %s\n' "$OVERRIDE_SRC" "$OVERRIDE_DEST"
        fi
        for entry in "${DATA_MOUNTS[@]}" "${DATA_FILE_MOUNTS[@]}"; do
            printf '%s -> %s\n' "$WS_AGENT_DIR/${entry%%|*}" "${entry#*|}"
        done
        true
    } | sort -u )
    # Escape CONFIG_ROOT for use as a literal in the grep ERE (dots only; the
    # mount destination lives under it, plus the /workspace mount).
    config_root_ere="$(printf '%s' "$CONFIG_ROOT" | sed 's/\./\\./g')"
    actual=$( docker inspect -f '{{range .Mounts}}{{.Source}} -> {{.Destination}}{{"\n"}}{{end}}' "$CONTAINER_NAME" 2>/dev/null | grep -E " -> (/workspace|${config_root_ere})(/|\$)" | sort -u || true )
    if [ -n "$actual" ] && [ "$expected" != "$actual" ]; then
        missing=$(comm -23 <(printf '%s\n' "$expected") <(printf '%s\n' "$actual"))
        extra=$(comm -13 <(printf '%s\n' "$expected") <(printf '%s\n' "$actual"))
        _msg=""
        [ -n "$missing" ] && _msg+="missing mount: $missing"$'\n'
        [ -n "$extra" ] && _msg+="  extra mount: $extra"$'\n'
        confirm_recreate "${_msg%$'\n'}"
    fi
fi

# Ensure host-side config & workspace dirs are present and owned by us before
# bringing the container up (Docker recreates missing bind-mount sources as
# root, which makes them unwritable by the in-container ubuntu user).
prepare_config

if [ -z "$EXISTING" ]; then
    # No existing container — build the image and create one.
    echo "Building a new container $CONTAINER_NAME"
    docker build \
        $NO_CACHE \
        --build-arg HOST_UID="$(id -u)" \
        --build-arg HOST_GID="$(id -g)" \
        -t "$IMAGE_TAG" \
        "$BUILD_DIR"

    VOLUMES=(-v "$WORKSPACE_DIR:/workspace")
    # See the drift `expected` block above: for Claude/Codex the override shares
    # the config mount's destination, so it replaces the shared config mount;
    # for pi it is an extra sub-mount at ~/.pi/agent.
    if [ -d "$OVERRIDE_SRC" ] && [ "$OVERRIDE_DEST" = "$CONFIG_MOUNT_DEST" ]; then
        VOLUMES+=(-v "$OVERRIDE_SRC:$CONFIG_MOUNT_DEST")
    else
        VOLUMES+=(-v "$CONFIG_MOUNT_SRC:$CONFIG_MOUNT_DEST")
        if [ -d "$OVERRIDE_SRC" ]; then
            VOLUMES+=(-v "$OVERRIDE_SRC:$OVERRIDE_DEST")
        fi
    fi
    for entry in "${DATA_MOUNTS[@]}" "${DATA_FILE_MOUNTS[@]}"; do
        VOLUMES+=(-v "$WS_AGENT_DIR/${entry%%|*}:${entry#*|}")
    done

    # --no-network: attach to the shared --internal network (egress blocked)
    # and point host.docker.internal at that network's on-link gateway so the
    # host stays reachable. `host-gateway` resolves to docker0, which is
    # off-subnet for an internal network and would be dropped, so the gateway
    # IP is used directly. Otherwise the default bridge + host-gateway is used.
    NETWORK_OPT=""
    ADD_HOST=(--add-host=host.docker.internal:host-gateway)
    if [ "$NO_NETWORK" = true ]; then
        ensure_no_net_network "$NO_NET_NETWORK"
        gw="$(docker network inspect -f '{{range .IPAM.Config}}{{.Gateway}}{{end}}' "$NO_NET_NETWORK" 2>/dev/null)"
        NETWORK_OPT="--network=$NO_NET_NETWORK"
        ADD_HOST=(--add-host=host.docker.internal:"${gw:-host-gateway}")
    fi

    echo "Starting container $CONTAINER_NAME"
    docker run -d \
        --name "$CONTAINER_NAME" \
        --entrypoint sleep \
        "${ADD_HOST[@]}" \
        $NETWORK_OPT \
        "${AGENT_ENV[@]}" \
        "${VOLUMES[@]}" \
        -w /workspace \
        "$IMAGE_TAG" \
        infinity
else
    # Existing container — bring it to a usable state.
    WAITED=0
    while true; do
        STATUS=$(docker inspect -f '{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null || echo "missing")
        case "$STATUS" in
            running)
                # If only the idle sleep process remains, a stop may be in progress.
                if [ "$(docker top "$CONTAINER_NAME" -o pid 2>/dev/null | tail -n +2 | wc -l)" -le 1 ] && [ "$WAITED" -lt 15 ]; then
                    [[ "$WAITED" -eq 0 ]] && echo "Waiting for $CONTAINER_NAME to finish stopping"
                    sleep 1; WAITED=$((WAITED + 1)); continue
                fi
                break
                ;;
            exited|dead|created)
                echo "Starting container $CONTAINER_NAME"
                docker start "$CONTAINER_NAME" >/dev/null
                break
                ;;
            paused)
                echo "Unpausing container $CONTAINER_NAME"
                docker unpause "$CONTAINER_NAME" >/dev/null
                break
                ;;
            *)
                [[ "$WAITED" -eq 0 ]] && echo "Waiting for $CONTAINER_NAME to reach a stable state"
                sleep 1; WAITED=$((WAITED + 1))
                ;;
        esac
    done
fi

# Probe real outbound connectivity and host reachability for --no-network.
probe_internet() {
    docker exec "$CONTAINER_NAME" node -e '
      const s = require("net").connect(443, "1.1.1.1");
      s.setTimeout(2000);
      s.on("connect",  () => process.exit(0));
      s.on("error",    () => process.exit(1));
      s.on("timeout",  () => { s.destroy(); process.exit(1); });
    ' >/dev/null 2>&1
}
# REFUSED on a closed port means the host stack answered (reachable); timeout means unreachable.
probe_host() {
    docker exec "$CONTAINER_NAME" node -e '
      const s = require("net").connect(9, "host.docker.internal");
      s.setTimeout(2000);
      s.on("connect",  () => process.exit(0));
      s.on("error",  e => process.exit((e.code==="ECONNREFUSED"||e.code==="EACCES"||e.code==="ECONNRESET") ? 0 : 1));
      s.on("timeout",  () => { s.destroy(); process.exit(1); });
    ' >/dev/null 2>&1
}
if [ "$NO_NETWORK" = true ]; then
    # The container is on $NO_NET_NETWORK by construction (encoded in its name);
    # verify the isolation actually holds rather than trusting the network name.
    if probe_internet; then
        echo "pipod: --no-network is set but $CONTAINER_NAME can still reach the Internet." >&2
        echo "pipod: egress isn't blocked — recreate the network with:" >&2
        echo "         docker network rm $NO_NET_NETWORK && ./pipod -r -nn" >&2
    elif ! probe_host; then
        echo "pipod: --no-network is set but $CONTAINER_NAME can't reach the host (host.docker.internal)." >&2
        echo "pipod: the host should still be reachable — recreate the network with:" >&2
        echo "         docker network rm $NO_NET_NETWORK && ./pipod -r -nn" >&2
    else
        echo "Network: isolated ($NO_NET_NETWORK) — host reachable, no Internet."
    fi
fi

# Run an agent session or bash shell. `--no-tty` drops the `-t` (no pseudo-tty)
# so stdin can be piped or the agent run non-interactively; EXTRA_ARGS (set by
# `--`) is appended to the agent command — or to `bash` in shell mode.
EXEC_FLAGS=(-it)
[ "$NO_TTY" = true ] && EXEC_FLAGS=(-i)
if [ "$SHELL_MODE" = true ]; then
    echo "Opening bash shell inside $CONTAINER_NAME container"
    docker exec "${EXEC_FLAGS[@]}" "$CONTAINER_NAME" bash "${EXTRA_ARGS[@]}"
else
    echo "Starting a new $AGENT_LABEL session inside $CONTAINER_NAME container"
    docker exec "${EXEC_FLAGS[@]}" "$CONTAINER_NAME" "${RUN_CMD[@]}" "${EXTRA_ARGS[@]}"
fi

# Auto-stop container when only the sleep idle process remains.
if [ "$(docker top "$CONTAINER_NAME" -o pid 2>/dev/null | tail -n +2 | wc -l)" -le 1 ]; then
    echo "Stopping $CONTAINER_NAME"
    docker kill "$CONTAINER_NAME" >/dev/null 2>&1 &
fi
